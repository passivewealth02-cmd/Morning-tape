# Anthropic API (for AI ticket categorization)
ANTHROPIC_API_KEY=sk-ant-...

# Neon Database (PostgreSQL)
DATABASE_URL=postgresql://...

# Resend Email
RESEND_API_KEY=re_...

# Vercel Blob (for ticket file/photo uploads)
# Auto-provisioned when you create a Blob store in the Vercel dashboard
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# App URL
NEXT_PUBLIC_APP_URL=https://your-domain.com
